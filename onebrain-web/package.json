  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.10",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
