# Copy to .env and edit. All values are optional — the defaults run with no keys.

# Providers: "local" needs no API key. Switch to "litellm" for real models.
# Staging and production must use pgvector plus enforced RLS.
ONEBRAIN_EMBEDDINGS_PROVIDER=litellm      # local | litellm
ONEBRAIN_LLM_PROVIDER=litellm             # local | litellm
ONEBRAIN_VECTOR_STORE=memory              # memory | pgvector
ONEBRAIN_ENVIRONMENT=local                # local | development | staging | production

# Retrieval
ONEBRAIN_TOP_K=8
# Immutable vector contract. Match this to the configured embedding model and
# existing pgvector `chunks.embedding` column; changing it requires re-embedding.
ONEBRAIN_EMBEDDING_DIM=256

# --- Gemini (Google AI Studio) -------------------------------------------
# One key covers both chat and embeddings.
GEMINI_API_KEY=your-gemini-key-here
ONEBRAIN_LITELLM_MODEL=gemini/gemini-2.5-flash
ONEBRAIN_LITELLM_EMBEDDING_MODEL=gemini/gemini-embedding-001

# --- To switch providers later, change only these three lines, e.g.: ------
# Mistral (EU):   MISTRAL_API_KEY=...   model=mistral/mistral-small-latest   embed=mistral/mistral-embed
# OpenAI:         OPENAI_API_KEY=...    model=openai/gpt-4o-mini             embed=openai/text-embedding-3-small
# Anthropic:      ANTHROPIC_API_KEY=... model=anthropic/claude-sonnet-4-5    (needs a separate embeddings provider)

# --- Per-tier sovereignty routing (Schrems II) ---------------------------
# CONFIDENTIAL/RESTRICTED answers route here; PUBLIC/INTERNAL use the default
# model above. Leave empty to disable (everything uses the default).
# ONEBRAIN_SOVEREIGN_LLM_MODEL=mistral/mistral-large-latest   # an EU-sovereign endpoint
# ONEBRAIN_SOVEREIGN_MIN_TIER=confidential                    # public|internal|confidential|restricted
# ONEBRAIN_SOVEREIGN_REQUIRED=false   # true = refuse sensitive answers when no sovereign endpoint is set

# pgvector (only used when vector_store = pgvector)
ONEBRAIN_DATABASE_URL=postgresql://user:pass@localhost:5432/onebrain
ONEBRAIN_MIGRATION_DATABASE_URL=          # optional owner/service-role URL for Alembic
# Worker-only DSN. Do not inject it into the API container: the worker login is
# permitted to claim jobs across tenant scopes, while the API login is not.
# ONEBRAIN_WORKER_DATABASE_URL=postgresql://onebrain_worker:<password>@postgres:5432/onebrain
ONEBRAIN_RLS_ENFORCED=false               # true for staging/production
# Explicit non-owner roles required by the job-queue RLS migration in production.
# ONEBRAIN_POSTGRES_APP_ROLE=onebrain_app
# ONEBRAIN_POSTGRES_WORKER_ROLE=onebrain_worker
# Product-local runtime logins for the separately migrated assistant and
# communication databases. These credentials are not the Postgres owner.
# ONEBRAIN_POSTGRES_ASSISTANT_ROLE=assistant_app
# ONEBRAIN_POSTGRES_COMMUNICATION_ROLE=communication_app

# Auth — REQUIRED. The app refuses to start without a strong (>=32 char) secret.
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
ONEBRAIN_AUTH_SECRET=REPLACE_ME
ONEBRAIN_SESSION_DAYS=7
ONEBRAIN_COOKIE_SECURE=false   # true in production (https); false for local http dev
# Required in staging/production: separate 32+ character secret used to
# HMAC login, service-key, and fleet rate-limit keys before PostgreSQL stores them.
ONEBRAIN_LOGIN_RATE_LIMIT_SECRET=REPLACE_WITH_ANOTHER_32_CHAR_SECRET
# Forwarded client addresses are ignored by default. Set both only when a known
# reverse proxy is directly in front of the API; hops includes that direct proxy.
# ONEBRAIN_TRUSTED_PROXY_CIDRS=10.0.0.0/8
# ONEBRAIN_TRUSTED_PROXY_HOPS=1

# --- Login accounts ------------------------------------------------------
# The SAFE production login: a real admin, ensured on boot (no shared password).
ONEBRAIN_ADMIN_EMAIL=admin@example.com
ONEBRAIN_ADMIN_PASSWORD=set-a-strong-password
# Shared-password demo accounts (email + "onebrain2026"). They auto-seed ONLY on a
# fully-local stack. On a real stack (litellm/pgvector) they do NOT seed unless you
# opt in below. To rotate an already-seeded deployment: python scripts/secure_users.py
ONEBRAIN_SEED_DEMO_USERS=true
ONEBRAIN_ALLOW_DEMO_USERS=false   # set true ONLY for a deliberately-public demo

# --- Publication lifecycle (human-error firewall) ------------------------
# require_approval: every upload waits in quarantine for a second person to approve.
# pii_phase: while "synthetic", any upload containing real PII is refused (a code
#            gate for "synthetic data only until the DPIA is signed").
# ONEBRAIN_REQUIRE_APPROVAL=false
# ONEBRAIN_BLOCK_PUBLIC_ON_PII=true
# ONEBRAIN_PII_PHASE=synthetic          # synthetic | dpia_signed; use dpia_signed only for controlled real-data testing

# Seeding / persistence
ONEBRAIN_SEED_SAMPLE_DATA=true
ONEBRAIN_PERSIST=true

# Worker/deployment startup
# Set ONEBRAIN_PROCESS=worker on the worker service; omit or set api on the API service.
# ONEBRAIN_PROCESS=api
ONEBRAIN_WORKER_POLL_SECONDS=2
ONEBRAIN_WORKER_BATCH_SIZE=1
ONEBRAIN_JOB_MAX_ATTEMPTS=3
ONEBRAIN_SCHEMA_WAIT_SECONDS=60
ONEBRAIN_SCHEMA_WAIT_POLL_SECONDS=2
# ONEBRAIN_WORKER_HEALTH_SERVER=true

# --- Staging/production minimum ------------------------------------------
# ONEBRAIN_ENVIRONMENT=production
# ONEBRAIN_VECTOR_STORE=pgvector
# ONEBRAIN_DATABASE_URL=postgresql://onebrain_app:<password>@postgres:5432/onebrain
# ONEBRAIN_MIGRATION_DATABASE_URL=postgresql://onebrain_owner:<password>@postgres:5432/onebrain
# ONEBRAIN_WORKER_DATABASE_URL=postgresql://onebrain_worker:<password>@postgres:5432/onebrain
# ONEBRAIN_POSTGRES_APP_ROLE=onebrain_app
# ONEBRAIN_POSTGRES_WORKER_ROLE=onebrain_worker
# ONEBRAIN_POSTGRES_ASSISTANT_ROLE=assistant_app
# ONEBRAIN_POSTGRES_COMMUNICATION_ROLE=communication_app
# ONEBRAIN_RLS_ENFORCED=true
# ONEBRAIN_COOKIE_SECURE=true
# ONEBRAIN_PII_PHASE=dpia_signed
# ONEBRAIN_AUTH_SECRET=<strong random secret, at least 32 chars>
# ONEBRAIN_ADMIN_EMAIL=<admin email>
# ONEBRAIN_ADMIN_PASSWORD=<strong admin password>

# --- Customer provisioning --------------------------------------------------
# Provisioning is disabled by default. The only supported active backend is the
# private Hetzner broker path; legacy GitHub/Railway dispatch is intentionally
# not a selectable backend.
ONEBRAIN_PROVISIONER_BACKEND=disabled     # disabled | hetzner
# ONEBRAIN_SECRET_ENCRYPTION_KEY=<fernet key or 32-byte hex>
# ONEBRAIN_SECRET_ENCRYPTION_KEY_VERSION=v1
# ONEBRAIN_BOOTSTRAP_SECRET_TTL_SECONDS=3600

# --- Optional AI Employees: Google Workspace Calendar ----------------------
# Direct-turn leases prevent duplicate paid model calls if a streaming request
# is interrupted. Keep provider timeout below the lease duration.
# ONEBRAIN_AI_EMPLOYEES_RUN_LEASE_SECONDS=120
# ONEBRAIN_AI_EMPLOYEES_RUN_HEARTBEAT_SECONDS=15
# ONEBRAIN_AI_EMPLOYEES_PROVIDER_TIMEOUT_SECONDS=60
# OAuth tokens are encrypted behind opaque secret:// references using the
# deployment secret-encryption key above. Register this exact callback URI in
# Google Cloud. Production/staging callback URIs must use HTTPS.
# ONEBRAIN_AI_EMPLOYEES_GOOGLE_CLIENT_ID=<google-oauth-web-client-id>
# ONEBRAIN_AI_EMPLOYEES_GOOGLE_CLIENT_SECRET=<google-oauth-web-client-secret>
# ONEBRAIN_AI_EMPLOYEES_GOOGLE_REDIRECT_URI=https://onebrain.example/ai-employees/google-calendar/callback
# ONEBRAIN_AI_EMPLOYEES_GOOGLE_TIMEOUT_SECONDS=10
# ONEBRAIN_AI_EMPLOYEES_CONNECTOR_SECRET_STORE_PATH=/var/lib/onebrain/ai-employee-connector-secrets.json

# --- Release promotion (Mission Control; manual customer rollout) ----------
# Production release verification remains the offline-key trust source for customers.
# The development public key verifies CI candidates and is trusted only by the dev gate.
# Generate the candidate hash with:
# python -c "from app.fleet.keys import hash_secret; print(hash_secret('replace-me'))"
# ONEBRAIN_RELEASE_VERIFY_PUBLIC_KEY=<offline production release public key>
# ONEBRAIN_DEV_RELEASE_VERIFY_PUBLIC_KEY=<development CI public key>
# ONEBRAIN_RELEASE_CANDIDATE_KEY_ID=candidate-ci-v1
# ONEBRAIN_RELEASE_CANDIDATE_KEY_HASH=sha256$...
# Production Mission Control fails startup unless all release gates below are on.
# ONEBRAIN_RELEASE_REQUIRE_SIGNATURE=true
# ONEBRAIN_RELEASE_REQUIRE_SIGNED_IMAGES=true
# ONEBRAIN_RELEASE_REQUIRE_ROLLBACK_KIND=true
# ONEBRAIN_RELEASE_PROMOTION_REQUIRED=true

# --- Mission Control -> private Hetzner broker ------------------------------
# MC sends only typed provisioning requests over mTLS. It MUST NOT receive the
# Hetzner Cloud token; that token belongs only in deploy/broker/broker.env on
# the dedicated broker host.
# ONEBRAIN_HETZNER_BROKER_URL=https://broker.example
# ONEBRAIN_HETZNER_BROKER_CREDENTIAL=<MC-only-broker-credential>
# ONEBRAIN_HETZNER_BROKER_CLIENT_CERTIFICATE_FILE=/root/broker-tls/mc-client.crt
# ONEBRAIN_HETZNER_BROKER_CLIENT_KEY_FILE=/root/broker-tls/mc-client.key
# ONEBRAIN_HETZNER_BROKER_CA_FILE=/root/broker-tls/broker-ca.crt
# ONEBRAIN_HETZNER_BROKER_TIMEOUT_SECONDS=10
# ONEBRAIN_HETZNER_API_TOKEN=  # MUST stay empty on MC when a broker URL is set

# --- Mission Control fleet settings (all inert by default) ------------------
# These settings belong only on MC. Customer applications never receive fleet
# credentials. Keep reconciliation disabled until the broker and dev-gate
# rollout path are verified end to end.
#
# Desired-state wrapper-key custody + rotation (P5-02). MC signs desired-state with
# the ONE online private key; boxes accept ANY public key in the delivered set. To
# rotate without a flag day, set the overlap SET to "<old_pub>,<new_pub>" and bump
# every box's secrets_epoch (POST /api/fleet/rotate-desired-state-key). See
# scripts/rotate_desired_state_key.py.
# ONEBRAIN_FLEET_DESIRED_STATE_PRIVATE_KEY=<base64 raw Ed25519; MC ONLY; NOT the release key>
# ONEBRAIN_FLEET_DESIRED_STATE_PUBLIC_KEY=<base64 raw Ed25519; singular fallback>
# ONEBRAIN_FLEET_DESIRED_STATE_PUBLIC_KEYS=   # csv accepted-key SET (rotation overlap); "" -> singular fallback
# ONEBRAIN_FLEET_URL=https://mc.example.com         # HTTPS is required on production MC
# ONEBRAIN_FLEET_PUBLIC_URL=https://mc.example.com  # HTTPS public enrollment origin
#
# First-boot bootstrap-token exchange (P5-03): the validity window of the single-use
# token a fresh box exchanges once for its secret bundle, plus a DEDICATED, aggressively-
# low rate limit on POST /api/fleet/bootstrap (one fetch exfiltrates the whole bundle, so
# it is capped far below the 120/60s heartbeat budget — G1-5). Keyed per deployment.
# ONEBRAIN_FLEET_BOOTSTRAP_TOKEN_TTL_SECONDS=3600
# ONEBRAIN_FLEET_BOOTSTRAP_RATE_LIMIT=5
# ONEBRAIN_FLEET_BOOTSTRAP_RATE_WINDOW_SECONDS=60
#
# In-process pull-reconcile scheduler (P5-04). 0 = DISABLED (default) even on an
# operator instance — auto-advance is opt-in, never flipped by a deploy. Set a
# positive interval (clamped to a 30s floor) to enable on MC.
# ONEBRAIN_FLEET_RECONCILE_SECONDS=60
#
# Fleet health watchdog. On Mission Control it checks every registered
# deployment every 60 seconds by default; set 0 only to disable it explicitly.
# It opens/resolves low-disk alerts when usable free space is at or below the
# configured percentage. The data path is the persistent PostgreSQL mount, not
# the application /data directory; a reporter that cannot see it reports 0/0.
# ONEBRAIN_FLEET_WATCHDOG_SECONDS=60
# ONEBRAIN_FLEET_LOW_ROOT_DISK_PERCENT=15
# ONEBRAIN_FLEET_LOW_DATA_DISK_PERCENT=15
# ONEBRAIN_FLEET_DATA_VOLUME_PATH=/mnt/onebrain-data
#
# The direct Hetzner settings below are legacy compatibility settings. The
# Hetzner API token must live only on the private broker, never on MC or a
# customer host. Do not enable this direct-provider path for production.
#
# Hetzner DNS + default-deny Cloud Firewall (P5-05). DNS uses the UNIFIED Hetzner Cloud
# API (GA 2025-11-10): the SAME ONEBRAIN_HETZNER_API_TOKEN as compute (Bearer) covers DNS
# — there is NO separate DNS token (the legacy dns.hetzner.com + Auth-API-Token path is
# gone). DNS is skipped unless the provider is "hetzner" with a zone + base domain. SSH
# inbound (22) is emitted ONLY as a deliberate break-glass — default false = no inbound 22.
# ONEBRAIN_FLEET_DNS_PROVIDER=hetzner
# ONEBRAIN_FLEET_DNS_ZONE_ID=<Hetzner Cloud DNS zone id or name (the rrset path accepts either)>
# ONEBRAIN_FLEET_BASE_DOMAIN=fleet.example   # -> <deployment_id>.fleet.example
# ONEBRAIN_HETZNER_FIREWALL_ALLOW_SSH=false
