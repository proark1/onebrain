# Copy to broker.env (0600, root-owned) on the dedicated broker host only.
# Never put these values on Mission Control, a customer server, or in Git.

HETZNER_BROKER_API_TOKEN=replace-with-hetzner-cloud-token
# Generate from the MC-only raw credential with app.servicekeys.base.hash_secret.
HETZNER_BROKER_MC_TOKEN_HASH=sha256$replace-with-hash-only

HETZNER_BROKER_LOCATIONS=nbg1,fsn1,hel1
HETZNER_BROKER_SERVER_TYPES=cx23
HETZNER_BROKER_IMAGE=ubuntu-24.04
HETZNER_BROKER_DNS_ZONE_ID=replace-with-approved-zone-id-or-name
HETZNER_BROKER_MAX_VOLUME_SIZE_GB=100
HETZNER_BROKER_MAX_FLEET_SERVERS=5
HETZNER_BROKER_ENABLE_BACKUPS=true
HETZNER_BROKER_ALLOW_SSH=false
# Leave both allowlists empty unless a reviewed break-glass exception requires them.
HETZNER_BROKER_SSH_KEY_IDS=
HETZNER_BROKER_FIREWALL_IDS=
HETZNER_BROKER_MAX_USER_DATA_BYTES=32768
